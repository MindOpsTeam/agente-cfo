# Agente CFO — Variáveis de ambiente
# O setup.sh gera ~/.agente-cfo/.env automaticamente.
# Este arquivo é só referência.

# ── Omie ERP (obrigatório) ────────────────────────────────────────────────────
OMIE_APP_KEY=
OMIE_APP_SECRET=

# ── WhatsApp destino dos alertas (obrigatório) ────────────────────────────────
# Formato E.164: +5511999999999
CFO_WHATSAPP_TO=+55

# ── LLM (obrigatório) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Orçamento LLM mensal em BRL (obrigatório) ─────────────────────────────────
LLM_BUDGET_BRL=50

# ── Painel (preenchido pelo setup.sh) ─────────────────────────────────────────
# URL do projeto Supabase do cliente (criado via Lovable Cloud)
PANEL_BASE_URL=https://<seu-projeto>.supabase.co/functions/v1
# Token gerado pelo setup.sh — deve ser configurado como secret no Supabase
PANEL_TOKEN=
# ID da instância retornado pelo /instance-register
INSTANCE_ID=

# ── Cloudflare Tunnel (preenchido pelo setup.sh) ──────────────────────────────
INGRESS_URL=
HOOKS_TOKEN=

# ── Skill Omie — path de instalação ──────────────────────────────────────────
OMIE_SKILL_PATH=/root/.openclaw/workspace/skills/omie

# ── Preços LLM em BRL (opcional — defaults p/ Claude Sonnet 4.6) ──────────────
# LLM_INPUT_PRICE_BRL=9.50
# LLM_OUTPUT_PRICE_BRL=47.50
# LLM_MODEL=anthropic/claude-sonnet-4-6

# ── Diretórios (opcional) ─────────────────────────────────────────────────────
# CFO_LOG_DIR=/root/.agente-cfo/logs
# CFO_STATE_DIR=/root/.agente-cfo
