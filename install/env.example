# Agente CFO — Variáveis de ambiente
# Copie para ~/.agente-cfo/.env e preencha com valores reais.
# O setup.sh gera esse arquivo automaticamente.

# ── Licença (obrigatório) ──────────────────────────────────────────────────────
LICENSE_KEY=lk_...

# ── Omie ERP (obrigatório) ────────────────────────────────────────────────────
OMIE_APP_KEY=
OMIE_APP_SECRET=

# ── WhatsApp destino dos alertas (obrigatório) ────────────────────────────────
# Formato E.164: +5511999999999
CFO_WHATSAPP_TO=+55

# ── LLM (obrigatório) ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Orçamento LLM mensal em BRL (obrigatório) ─────────────────────────────────
LLM_BUDGET_BRL=50

# ── Painel central (preenchido pelo setup.sh após register) ───────────────────
PANEL_BASE_URL=https://odhcfrgydjluxunhvojp.supabase.co/functions/v1
INSTANCE_ID=
TENANT_ID=

# ── Cloudflare Tunnel (preenchido pelo setup.sh) ──────────────────────────────
INGRESS_URL=
HOOKS_TOKEN=

# ── Skill Omie — path de instalação (padrão seguro, raramente muda) ───────────
OMIE_SKILL_PATH=/root/.openclaw/workspace/skills/omie

# ── Preços LLM em BRL (opcional — defaults p/ Claude Sonnet 4.6) ──────────────
# LLM_INPUT_PRICE_BRL=9.50
# LLM_OUTPUT_PRICE_BRL=47.50
# LLM_MODEL=anthropic/claude-sonnet-4-6

# ── Diretórios (opcional — defaults seguros) ──────────────────────────────────
# CFO_LOG_DIR=/root/.agente-cfo/logs
# CFO_STATE_DIR=/root/.agente-cfo
