# Agente CFO — Painel Central
# Copie para .env e preencha com valores reais.
# NUNCA comite o .env.

# ── Supabase ────────────────────────────────────────────────────────────────
# Encontre em: https://supabase.com/dashboard/project/<project_ref>/settings/api
SUPABASE_URL=https://<project_ref>.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Configurações de negócio ────────────────────────────────────────────────
# Orçamento LLM mensal padrão para novos tenants (em BRL)
LLM_DEFAULT_BUDGET_BRL=50

# ── Supabase CLI (apenas dev) ───────────────────────────────────────────────
# Necessário apenas para rodar supabase db push / functions deploy
SUPABASE_ACCESS_TOKEN=sbp_...  # Personal Access Token de https://supabase.com/dashboard/account/tokens
